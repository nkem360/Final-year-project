# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pet_health_db

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── AI / Knowledge Base ──────────────────────────────────────────────────────
# Path to FAISS index (created by running ingest)
VECTOR_STORE_PATH=./knowledge_base/faiss_index
# Path to source vet documents (.txt, .pdf, .docx, .md)
KNOWLEDGE_BASE_PATH=./knowledge_base/documents
# Embedding model (HuggingFace — used if sentence-transformers is installed)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@example.com

# ─── AWS S3 (optional — for pet image uploads) ───────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=pet-health-images
AWS_REGION=us-east-1
